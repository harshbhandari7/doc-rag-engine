# doc-rag-engine — environment configuration
#
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Required fields are marked [REQUIRED].
# Everything else has a working default you can leave as-is.

# =============================================================================
# LLM — any OpenAI-compatible endpoint                              [REQUIRED]
# =============================================================================
#
# Option A: Ollama cloud  (https://ollama.com)
#   Sign up → Settings → API Keys → create a key.
#   Free plan includes gemma3:4b (generation) and gemma3:12b (eval judge).
#   Do NOT add /v1/ to the URL — the code appends it automatically.
#
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your_api_key_here
OLLAMA_MODEL=gemma3:4b

#
# Option B: Local Ollama  (ollama.com/download → install → ollama run gemma3:4b)
#   Comment out Option A and uncomment below:
#
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_MODEL=gemma3:4b

OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=1024
REQUEST_TIMEOUT=60

# =============================================================================
# RAGAS evaluation judge                                            [REQUIRED]
# =============================================================================
#
# A larger model than the generation model improves metric reliability.
# On the free Ollama tier, gemma3:12b is a good balance.
# Set RAGAS_MAX_WORKERS=2 to avoid 429s on free-tier rate limits.
#
RAGAS_JUDGE_MODEL=gemma3:12b
RAGAS_MAX_WORKERS=2

# =============================================================================
# Qdrant vector store
# =============================================================================
#
# Default: local Docker container started with `docker compose up -d`.
# Change host/port only if you run Qdrant on a different machine or port.
#
APP_QDRANT_HOST=localhost
APP_QDRANT_PORT=6333

# Collection names — one per chunking strategy. Change only if you want
# to run multiple experiments side-by-side.
APP_COLLECTION_FIXED=rag_fixed
APP_COLLECTION_RECURSIVE=rag_recursive
APP_COLLECTION_SEMANTIC=rag_semantic

# =============================================================================
# Embeddings
# =============================================================================
#
# Dense model: sentence-transformers hub name. MiniLM is fast and small (~90 MB).
# Sparse model: fastembed hub name. SPLADE downloads ~500 MB on first use.
# Changing these requires re-indexing all three collections.
#
APP_DENSE_EMBEDDING_MODEL=all-MiniLM-L6-v2
APP_DENSE_EMBEDDING_DIM=384
APP_SPARSE_EMBEDDING_MODEL=prithivida/Splade_PP_en_v1

# =============================================================================
# Chunking
# =============================================================================
#
# chunk_size / chunk_overlap: shared by FixedSizeChunker and RecursiveChunker.
# semantic_breakpoint_threshold: percentile (0–100) for SemanticChunker breaks;
#   higher → fewer, larger chunks.
# Changing these requires re-indexing.
#
APP_CHUNK_SIZE=512
APP_CHUNK_OVERLAP=64
APP_SEMANTIC_BREAKPOINT_THRESHOLD=95

# =============================================================================
# Retrieval
# =============================================================================
#
# APP_RETRIEVAL_LIMIT: first-stage candidate pool size (dense + BM25 each fetch this many).
# APP_RERANK_TOP_N:    chunks passed to the LLM after cross-encoder reranking.
# APP_RRF_K:           RRF damping constant (60 is the original paper's default).
# APP_HYBRID_ALPHA:    dense weight in weighted fusion (0.7 = 70% semantic, 30% keyword).
# APP_RERANK_MODEL:    FlashRank cross-encoder (~90 MB, downloads to /tmp on first use).
#
APP_RETRIEVAL_LIMIT=20
APP_RERANK_TOP_N=5
APP_RRF_K=60
APP_HYBRID_ALPHA=0.7
APP_RERANK_MODEL=ms-marco-MiniLM-L-12-v2

# =============================================================================
# Generation defaults
# =============================================================================
#
# Evaluation-backed best configuration: recursive chunking + hybrid RRF + reranker
# scored highest on faithfulness (0.802) and context recall (0.944).
#
APP_DEFAULT_COLLECTION=rag_recursive
APP_DEFAULT_RETRIEVAL_METHOD=hybrid_rrf+rerank
APP_MAX_CONTEXT_CHARS=12000

# =============================================================================
# Ingestion
# =============================================================================
#
# APP_OCR_ENABLED: set to false for digital-native PDFs to skip OCR and speed
#   up indexing significantly. Leave true for scanned documents.
#
APP_OCR_ENABLED=true
APP_TABLE_STRUCTURE_ENABLED=true
APP_MIN_PAGE_CHARS=10
APP_MERGE_MIN_CHARS=50

# =============================================================================
# MLflow experiment tracking
# =============================================================================
#
# SQLite backend is fine for local use. Switch to a remote URI for team use.
#
MLFLOW_TRACKING_URI=sqlite:///mlruns.db
MLFLOW_EXPERIMENT_NAME=rag_chunking_comparison
